// Prisma Schema for QC Checking App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
}

model Scan {
  id           String   @id @default(cuid())
  nik          String   // NIK operator (dari scan barcode)
  nama         String?  // Nama operator
  machine      String   // Mesin (dari scan barcode)
  bobbinNr     String   // Bobbin number (dari scan barcode)
  subBy        String?  // Nama/NIK QC inspector yang submit
  alignment    String   // "OK" atau "NOT_OK"
  sudut        Float?
  susut        Float?
  remark       String?
  createdAt    DateTime @default(now())

  @@index([nik, createdAt])
  @@index([bobbinNr, createdAt])
  @@index([machine, createdAt])
  @@index([subBy, createdAt])
  @@index([createdAt])
}